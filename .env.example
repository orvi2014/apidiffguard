# Supabase (required for auth + data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres (migrations / Prisma)
DATABASE_URL=
DIRECT_URL=

# App URL (production: https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Checkout + Customer Portal + webhooks)
# Create Prices with lookup keys: apidiffguard_starter_monthly, apidiffguard_pro_monthly
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional integrations (not required for local MVP)
RESEND_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRIGGER_SECRET_KEY=
