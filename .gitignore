# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# fumadocs
.source

# playwright / e2e secrets
/e2e-artifacts/
/playwright-report/
/test-results/
/blob-report/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
